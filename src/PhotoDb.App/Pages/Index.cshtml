@page
@model PhotoLab.Pages.IndexModel
@{
    Layout = null; // Independent high-density portal view custom layout
}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PHOTO_LAB - high-density (.NET Razor Solution)</title>
    <!-- Use material symbols for pixel-perfect icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..24,300..500,0..1,-50..50" rel="stylesheet" />
    <link rel="stylesheet" href="/css/index.css" />
  </head>
  <body>
    <!-- 1. APP HEADER -->
    <photo-app-header id="app_header_comp"></photo-app-header>

    <!-- MAIN CONTAINER -->
    <div class="main-container">
      
      <!-- 2. SIDEBAR LEFT -->
      <nav class="sidebar-left">
        <photo-sidebar id="sidebar_comp"></photo-sidebar>
        <photo-filter-panel id="filter_panel_comp"></photo-filter-panel>
      </nav>

      <!-- 3. CONTENT AREA / GALLERY GRID -->
      <photo-image-grid id="image_grid_comp" class="content-view"></photo-image-grid>

      <!-- 4. SIDEBAR RIGHT / METADATA PANEL -->
      <photo-info-panel id="info_panel_comp" class="sidebar-right"></photo-info-panel>

    </div>

    <!-- 5. FOOTER STATUS BAR -->
    <photo-status-bar id="status_bar_comp"></photo-status-bar>

    <!-- ADD/EDIT LIBRARY DIALOG MODAL -->
    <photo-create-library-dialog id="library_dialog_comp"></photo-create-library-dialog>

    <!-- MAIN LIGHTBOX SCREEN VIEW -->
    <photo-lightbox id="lightbox_comp"></photo-lightbox>

    <!-- DYNAMIC POPUP TOAST FEEDBACK NOTIFICATIONS -->
    <div id="toast_container" class="toast-container"></div>

    <!-- PHOTO EDITOR DIALOG MODAL OVERLAY -->
    <photo-editor-dialog id="editor_dialog_comp"></photo-editor-dialog>

    <!-- ENTRY POINT SCRIPTS -->
    <script type="module" src="/js/main.js"></script>
  </body>
</html>
